# Copy to .env in this directory and fill in real values. .env is gitignored.

# Nebius (OpenAI-compatible)
NEBIUS_API_KEY=your-nebius-key-here
NEBIUS_API_BASE=https://api.studio.nebius.ai/v1
MODEL_NAME=openai/Qwen/Qwen3-Next-80B-A3B-Thinking

